	(text "OPA1612 High Performance\nLow-Noise Amp"
		(exclude_from_sim no)
		(at 146.05 171.704 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "046d9a4c-758b-4cb4-b60b-307458fcfe87")
	)
	(text "GND and GNDA all the same second layer \nfrom the top. Follow the new way of\nmaking one big ground plane for the second\nlayer and as much ground plane on top and \nbottom as possible, with the power plane on\nthe third layer."
		(exclude_from_sim no)
		(at 169.164 116.84 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "081a5efd-7cb3-4b2c-9987-855a45e2fab7")
	)
	(text "10 - 45 Ohm resistor \"hides\" \nthe downstream capacitance from\nthe Op-Amp, ensuring it stays stable."
		(exclude_from_sim no)
		(at 185.674 130.302 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "3725d834-52ea-4c8f-985b-f3873cd00f56")
	)
	(text "24.576 MHz osc.\n(allows 48 kHz \nor 96 kHz)"
		(exclude_from_sim no)
		(at 162.56 92.964 0)
		(effects
			(font
